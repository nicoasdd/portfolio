{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.local/schemas/about-frontmatter.schema.json",
  "title": "AboutFrontmatter",
  "description": "Frontmatter schema for the single About content file at src/content/about/profile.md. Mirrors the Zod schema declared in src/content.config.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "headline", "intro", "photo", "email", "skills"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Owner's display name."
    },
    "headline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Professional title / one-line tagline."
    },
    "intro": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "description": "Short single-paragraph teaser used by the landing-page AboutTeaser component."
    },
    "photo": {
      "type": "string",
      "minLength": 1,
      "description": "Path under public/ to the profile photo (e.g., /about/profile.webp)."
    },
    "photoAlt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Alt text for the profile photo. Defaults to 'Portrait of {name}' if omitted."
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email rendered as a mailto: link."
    },
    "location": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Optional location (e.g., 'Buenos Aires, Argentina' or 'Remote')."
    },
    "availability": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Optional availability/status (e.g., 'Open to opportunities')."
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 40
      },
      "description": "Flat list of skills/areas of expertise."
    },
    "socialLinks": {
      "type": "array",
      "default": [],
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Visible text and accessible name for the link."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://",
            "description": "Absolute http(s) URL."
          },
          "icon": {
            "type": "string",
            "enum": [
              "github",
              "linkedin",
              "x",
              "mastodon",
              "bluesky",
              "email",
              "website"
            ],
            "description": "Optional icon identifier. Unknown values fall back to a generic link glyph."
          }
        }
      }
    },
    "resumeUrl": {
      "type": "string",
      "minLength": 1,
      "description": "Optional resume/CV link. Either an absolute http(s) URL or a path beginning with '/' (resolved under public/)."
    }
  }
}
