{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.local/schemas/project-frontmatter.schema.json",
  "title": "Project Frontmatter",
  "description": "Contract for the YAML frontmatter of a project Markdown file under src/content/projects/<category>/<slug>.md. The site build will fail if a project file does not conform to this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "description",
    "role",
    "period",
    "techStack",
    "thumbnail"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Display name of the project."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "description": "One-line summary; appears on cards and as the page meta description."
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 80,
      "description": "URL slug. Optional; defaults to the filename without extension. MUST be globally unique across all categories."
    },
    "role": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Author's role on the project (e.g., 'Lead Engineer', 'Founder')."
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$",
          "description": "Start month in YYYY-MM format."
        },
        "end": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
            },
            {
              "type": "string",
              "const": "present"
            }
          ],
          "description": "End month in YYYY-MM format, or the literal 'present'."
        }
      }
    },
    "techStack": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 30
      },
      "description": "Technologies, frameworks, languages used."
    },
    "thumbnail": {
      "type": "string",
      "minLength": 1,
      "description": "Path (relative to public/) to the card thumbnail image. Must resolve to an existing file."
    },
    "screenshots": {
      "type": "array",
      "maxItems": 10,
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Additional images shown on the detail page. Paths relative to public/."
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "source": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        },
        "live": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        },
        "caseStudy": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        }
      },
      "description": "Optional external URLs."
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Surface on the landing page featured section."
    },
    "order": {
      "type": "integer",
      "minimum": 0,
      "default": 100,
      "description": "Sort order within a category (lower = earlier)."
    },
    "draft": {
      "type": "boolean",
      "default": false,
      "description": "If true, exclude from production builds."
    }
  }
}
