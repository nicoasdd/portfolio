---
import type { SocialIcon } from '../content.config';

interface SocialLink {
  label: string;
  url: string;
  icon?: SocialIcon;
}

interface Props {
  links: SocialLink[];
  ariaLabel?: string;
}

const { links, ariaLabel = 'Social and elsewhere' } = Astro.props;
---

{links.length > 0 && (
  <nav aria-label={ariaLabel} class="bp-social">
    <ul role="list" class="bp-social__list">
      {links.map((link) => (
        <li role="listitem">
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="bp-social-link"
          >
            <span aria-hidden="true" class="inline-flex w-4 h-4">
              {link.icon === 'github' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 .5a11.5 11.5 0 0 0-3.64 22.41c.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.21.7-3.89-1.55-3.89-1.55-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.74.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.4-5.26 5.69.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .5Z"/></svg>
              )}
              {link.icon === 'linkedin' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9.5h4v11H3v-11Zm6.5 0h3.83v1.5h.05c.53-1 1.84-2.07 3.79-2.07 4.05 0 4.8 2.66 4.8 6.13V20.5h-4V15.5c0-1.2-.02-2.74-1.67-2.74-1.68 0-1.94 1.31-1.94 2.66v5.08h-4v-11Z"/></svg>
              )}
              {link.icon === 'x' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2H21l-6.52 7.45L22 22h-6.825l-4.79-6.26L4.8 22H2l7.02-8.02L2 2h6.91l4.34 5.73L18.244 2Zm-1.197 18h1.86L7.04 4H5.05l11.997 16Z"/></svg>
              )}
              {link.icon === 'mastodon' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M21.6 8.7c0-4.4-2.9-5.7-2.9-5.7C17.2 2.3 14.7 2 12.1 2h-.1c-2.6 0-5 .3-6.5 1-.1 0-3 1.3-3 5.7v3.9c0 4.5 2.9 5.7 4.6 6 1.3.3 2.6.4 3.4.4 1.6 0 2.7-.2 3.5-.5l.1-.6c0-.3-.2-.4-.5-.3-.7.2-2 .5-3.7.4-2.4-.1-3.5-1.3-3.7-2.3 1.7.4 3.4.5 5 .4 1.5 0 2.9-.1 4.2-.4 2.7-.6 3.6-2.1 3.7-2.1.4-.4.6-2.6.6-3.5l.1-.4Zm-3.2 5.6h-2v-5c0-1-.4-1.5-1.3-1.5s-1.3.5-1.3 1.5v3h-2v-3c0-1-.4-1.5-1.3-1.5s-1.3.5-1.3 1.5v5H7.2v-5c0-2.1 1-3.2 3-3.2 1 0 1.8.4 2.3 1.2.5-.8 1.3-1.2 2.3-1.2 2 0 3 1.1 3 3.2l-.4 5Z"/></svg>
              )}
              {link.icon === 'bluesky' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M5 4c2.5 1.6 5.2 4.8 6.2 6.5L12 12l.8-1.5C13.8 8.8 16.5 5.6 19 4c1.7-1 4 .1 4 2.5 0 .9-.5 5.2-1 5.6-1 .7-2.4 1.1-4 1.4 2.5.4 4.8 1.2 4.8 4 0 3-2.6 4.5-5.5 4.5-3.4 0-5.3-2.5-5.3-5.6 0 3.1-1.9 5.6-5.3 5.6C2.6 22 0 20.5 0 17.5c0-2.8 2.3-3.6 4.8-4-1.6-.3-3-.7-4-1.4C.5 11.7 0 7.4 0 6.5 0 4.1 2.3 3 4 4Z"/></svg>
              )}
              {link.icon === 'email' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
              )}
              {link.icon === 'website' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2c3 3 4.5 6.5 4.5 10S15 19 12 22c-3-3-4.5-6.5-4.5-10S9 5 12 2Z"/></svg>
              )}
              {!link.icon && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M14 3h7v7"/><path d="M21 3 10 14"/><path d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"/></svg>
              )}
            </span>
            <span>{link.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .bp-social__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bp-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--bp-line);
    border-radius: var(--radius-bp-sm);
    background: var(--bp-surface);
    color: var(--bp-text);
    font-size: var(--text-bp-sm);
    font-weight: 500;
    text-decoration: none;
    transition: border-color 150ms ease-out, color 150ms ease-out;
  }

  .bp-social-link:hover {
    border-color: var(--bp-accent);
    color: var(--bp-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .bp-social-link {
      transition: none;
    }
  }
</style>
