---
interface Props {
  items: string[];
  ariaLabel?: string;
}

const { items, ariaLabel = 'Tech stack' } = Astro.props;
---

<div aria-label={ariaLabel}>
  <ul class="flex flex-wrap gap-2 list-none m-0 p-0">
    {items.map((item) => (
      <li class="text-sm px-3 py-1 rounded-full bg-[var(--color-bg-subtle)] text-[var(--color-text)] border border-[var(--color-border)]">
        {item}
      </li>
    ))}
  </ul>
</div>
