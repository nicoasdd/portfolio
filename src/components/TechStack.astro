---
import PillChip from './blueprint/PillChip.astro';

interface Props {
  items: string[];
  ariaLabel?: string;
}

const { items, ariaLabel = 'Tech stack' } = Astro.props;
---

<div aria-label={ariaLabel}>
  <ul class="bp-tech-stack" role="list">
    {items.map((item) => (
      <li role="listitem">
        <PillChip size="sm">{item}</PillChip>
      </li>
    ))}
  </ul>
</div>

<style>
  .bp-tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
