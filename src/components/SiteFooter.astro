---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-24">
  <div class="container-narrow py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-[var(--color-text-muted)]">
    <p class="m-0">© {year} Portfolio. Built with Astro.</p>
    <ul class="flex items-center gap-4 list-none m-0 p-0">
      <li>
        <a href="https://github.com/" rel="noopener" class="no-underline hover:underline">GitHub</a>
      </li>
      <li>
        <a href="mailto:hello@example.com" class="no-underline hover:underline">Email</a>
      </li>
    </ul>
  </div>
</footer>
