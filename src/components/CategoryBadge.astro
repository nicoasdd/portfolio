---
import { CATEGORY_LABELS, type CategoryKey } from '../content.config';

interface Props {
  category: CategoryKey;
  size?: 'sm' | 'md';
}

const { category, size = 'sm' } = Astro.props;

const colorVar: Record<CategoryKey, string> = {
  personal: 'var(--color-cat-personal)',
  startup: 'var(--color-cat-startup)',
  corporate: 'var(--color-cat-corporate)',
};

const padding = size === 'sm' ? 'px-2 py-0.5 text-xs' : 'px-3 py-1 text-sm';
---

<span
  class:list={[
    'inline-flex items-center rounded-full font-semibold uppercase tracking-wide text-white',
    padding,
  ]}
  style={`background-color: ${colorVar[category]};`}
>
  {CATEGORY_LABELS[category]}
</span>
