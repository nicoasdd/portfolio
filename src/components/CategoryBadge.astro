---
import { CATEGORY_LABELS, type CategoryKey } from '../content.config';

interface Props {
  category: CategoryKey;
  size?: 'sm' | 'md';
}

const { category, size = 'sm' } = Astro.props;
---

<span class:list={['bp-category-badge', `bp-category-badge--${size}`]}>
  {CATEGORY_LABELS[category].toUpperCase()}
</span>

<style>
  .bp-category-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-bp-mono);
    color: var(--bp-accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
  }

  .bp-category-badge--sm {
    font-size: var(--text-bp-xs);
  }

  .bp-category-badge--md {
    font-size: var(--text-bp-sm);
  }
</style>
