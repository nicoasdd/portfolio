---
import { withBase } from '../lib/url';

interface Props {
  heading?: string;
  intro?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  heading = 'Selected work across personal, startup, and corporate projects.',
  intro = 'A curated portfolio of things I have built — open-source weekend projects, startups I have co-founded, and large-scale corporate engineering.',
  ctaHref = '#projects',
  ctaLabel = 'See projects',
} = Astro.props;

const aboutHref = withBase('/about/');
---

<section class="container-narrow pt-12 md:pt-20 pb-12">
  <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight max-w-4xl m-0">
    {heading}
  </h1>
  <p class="mt-6 max-w-2xl text-lg md:text-xl text-[var(--color-text-muted)]">
    {intro}
  </p>
  <div class="mt-8 flex flex-wrap items-center gap-3">
    <a
      href={ctaHref}
      class="inline-flex items-center justify-center rounded-full bg-[var(--color-accent)] text-white font-semibold px-6 py-3 no-underline hover:bg-[var(--color-accent-hover)]"
    >
      {ctaLabel}
    </a>
    <a
      href={aboutHref}
      class="inline-flex items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text)] font-semibold px-6 py-3 no-underline hover:border-[var(--color-accent)]"
    >
      About
    </a>
  </div>
</section>
