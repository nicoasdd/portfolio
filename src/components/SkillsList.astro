---
interface Props {
  skills: string[];
  ariaLabel?: string;
}

const { skills, ariaLabel } = Astro.props;
---

<ul
  role="list"
  aria-label={ariaLabel}
  class="flex flex-wrap gap-2 list-none m-0 p-0"
>
  {skills.map((skill) => (
    <li
      role="listitem"
      class="text-sm px-3 py-1 rounded-full bg-[var(--color-bg-subtle)] text-[var(--color-text)] border border-[var(--color-border)]"
    >
      {skill}
    </li>
  ))}
</ul>
