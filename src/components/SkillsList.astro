---
import PillChip from './blueprint/PillChip.astro';

interface Props {
  skills: string[];
  ariaLabel?: string;
}

const { skills, ariaLabel } = Astro.props;
---

<ul role="list" aria-label={ariaLabel} class="bp-skills-list">
  {skills.map((skill) => (
    <li role="listitem">
      <PillChip size="md">{skill}</PillChip>
    </li>
  ))}
</ul>

<style>
  .bp-skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
