---
import { getAbout } from '../lib/about';
import { safeImagePath } from '../lib/assets';
import { withBase } from '../lib/url';

const profile = await getAbout();
const { data, effectiveAlt } = profile;
const photoSrc = safeImagePath(data.photo);
const aboutHref = withBase('/about/');
---

<section
  aria-labelledby="about-teaser-eyebrow"
  class="container-narrow my-12 md:my-16"
>
  <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 md:p-8 flex flex-col sm:flex-row items-center sm:items-start gap-6 sm:gap-8">
    <img
      src={photoSrc}
      alt={effectiveAlt}
      loading="lazy"
      decoding="async"
      width="160"
      height="160"
      class="block w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full object-cover bg-[var(--color-bg-subtle)] border border-[var(--color-border)] shrink-0"
    />
    <div class="text-center sm:text-left">
      <p
        id="about-teaser-eyebrow"
        class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] m-0"
      >
        About the author
      </p>
      <h2 id="about-teaser-heading" class="mt-1 text-2xl md:text-3xl font-bold tracking-tight m-0">
        {data.name}
      </h2>
      <p class="mt-1 text-base md:text-lg text-[var(--color-text-muted)] m-0">{data.headline}</p>
      <p class="mt-3 text-base text-[var(--color-text)] m-0">{data.intro}</p>
      <p class="mt-4 m-0">
        <a
          href={aboutHref}
          class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent)] no-underline hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
        >
          More about {data.name.split(' ')[0]}
          <span aria-hidden="true">→</span>
        </a>
      </p>
    </div>
  </div>
</section>
