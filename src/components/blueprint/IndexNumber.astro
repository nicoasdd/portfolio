---
interface Props {
  n: number;
  class?: string;
}

const { n, class: className = '' } = Astro.props;
const padded = String(n).padStart(2, '0');
---

<span class:list={['bp-index-number', className]} aria-hidden="true">
  <span class="bp-index-number__tick"></span>
  <span class="bp-index-number__num">{padded}</span>
</span>

<style>
  .bp-index-number {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-bp-mono);
    font-size: var(--text-bp-lg);
    color: var(--bp-accent);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .bp-index-number__tick {
    display: inline-block;
    width: 1rem;
    height: 1px;
    background: currentColor;
  }

  .bp-index-number__num {
    font-variant-numeric: tabular-nums;
  }
</style>
