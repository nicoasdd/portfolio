---
interface Props {
  trend?: 'up' | 'down' | 'flat';
  class?: string;
}

const { trend = 'up', class: className = '' } = Astro.props;

const POINTS: Record<NonNullable<Props['trend']>, string> = {
  up: '0,10 6,9 12,7 18,6 24,4 30,3 36,2 40,1',
  down: '0,1 6,2 12,3 18,5 24,6 30,8 36,9 40,10',
  flat: '0,6 6,5 12,7 18,5 24,6 30,5 36,6 40,5',
};
---

<svg
  class:list={['bp-sparkline', className]}
  width="40"
  height="12"
  viewBox="0 0 40 12"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <polyline points={POINTS[trend]} />
</svg>

<style>
  .bp-sparkline {
    display: inline-block;
    color: var(--bp-accent);
    vertical-align: middle;
  }
</style>
