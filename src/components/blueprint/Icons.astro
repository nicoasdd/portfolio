---
/*
  Single source for every blueprint icon.
  All paths use currentColor so icons theme-flip automatically.
  Keys match the Zod enums in src/content.config.ts:
  - ArchIconKey, PillIcon, ValueIcon, CredibilityIcon, SystemsIcon
*/

interface Props {
  name: string;
  size?: number;
  class?: string;
  ariaLabel?: string;
}

const { name, size = 20, class: className = '', ariaLabel } = Astro.props;
const ariaHidden = !ariaLabel;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden ? 'true' : undefined}
  aria-label={ariaLabel}
  role={ariaLabel ? 'img' : undefined}
>
  {/* Architecture icons */}
  {name === 'users' && (
    <g>
      <circle cx="9" cy="9" r="3" />
      <path d="M4 20a5 5 0 0 1 10 0" />
      <circle cx="17" cy="10" r="2.5" />
      <path d="M14.5 20a4 4 0 0 1 7 0" />
    </g>
  )}
  {name === 'api' && (
    <g>
      <rect x="3" y="7" width="18" height="10" rx="1.5" />
      <path d="M7 10h3M7 14h5M17 10l2 2-2 2" />
    </g>
  )}
  {name === 'db' && (
    <g>
      <ellipse cx="12" cy="5" rx="8" ry="3" />
      <path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5" />
      <path d="M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6" />
    </g>
  )}
  {name === 'cache' && (
    <g>
      <rect x="3" y="5" width="18" height="5" rx="1" />
      <rect x="3" y="14" width="18" height="5" rx="1" />
      <circle cx="6" cy="7.5" r="0.7" />
      <circle cx="6" cy="16.5" r="0.7" />
    </g>
  )}
  {name === 'queue' && (
    <g>
      <rect x="3" y="9" width="4" height="6" rx="1" />
      <rect x="9" y="9" width="4" height="6" rx="1" />
      <rect x="15" y="9" width="4" height="6" rx="1" />
      <path d="M21 12h1" />
    </g>
  )}
  {name === 'server' && (
    <g>
      <rect x="3" y="4" width="18" height="7" rx="1.5" />
      <rect x="3" y="13" width="18" height="7" rx="1.5" />
      <circle cx="7" cy="7.5" r="0.7" />
      <circle cx="7" cy="16.5" r="0.7" />
      <path d="M10 7.5h8M10 16.5h8" />
    </g>
  )}
  {name === 'web' && (
    <g>
      <rect x="3" y="4" width="18" height="16" rx="1.5" />
      <path d="M3 9h18" />
      <circle cx="6" cy="6.5" r="0.6" />
      <circle cx="8.5" cy="6.5" r="0.6" />
    </g>
  )}
  {name === 'messaging' && (
    <g>
      <path d="M4 5h16v10H8l-4 4V5z" />
    </g>
  )}
  {name === 'blockchain' && (
    <g>
      <rect x="3" y="3" width="6" height="6" rx="1" />
      <rect x="15" y="3" width="6" height="6" rx="1" />
      <rect x="3" y="15" width="6" height="6" rx="1" />
      <rect x="15" y="15" width="6" height="6" rx="1" />
      <path d="M9 6h6M9 18h6M6 9v6M18 9v6" />
    </g>
  )}
  {name === 'cloud' && (
    <g>
      <path d="M7 17a4 4 0 1 1 .7-7.9A5 5 0 0 1 17 9a4 4 0 0 1 0 8H7z" />
    </g>
  )}

  {/* Pill icons (availability) */}
  {name === 'remote' && (
    <g>
      <path d="M3 7h18M3 12h18M3 17h12" />
      <circle cx="18" cy="17" r="2" />
    </g>
  )}
  {name === 'onsite' && (
    <g>
      <path d="M3 21V8l9-5 9 5v13" />
      <rect x="9" y="13" width="6" height="8" />
    </g>
  )}
  {name === 'hybrid' && (
    <g>
      <path d="M4 20h16M7 10l5-6 5 6" />
      <path d="M9 10v10M15 10v10" />
    </g>
  )}
  {name === 'collab' && (
    <g>
      <circle cx="8" cy="10" r="3" />
      <circle cx="16" cy="10" r="3" />
