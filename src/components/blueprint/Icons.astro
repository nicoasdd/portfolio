  {name === 'architecture' && (
    <g>
      <path d="M3 21l9-18 9 18z" />
      <path d="M7 14h10M12 3v18" />
    </g>
  )}
  {name === 'web3' && (
    <g>
      <circle cx="12" cy="12" r="9" />
      <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />
    </g>
  )}
  {name === 'fintech' && (
    <g>
      <rect x="3" y="6" width="18" height="12" rx="1.5" />
      <circle cx="12" cy="12" r="3" />
      <path d="M6 9v.01M18 15v.01" />
    </g>
  )}
  {name === 'marketplace' && (
    <g>
      <path d="M3 7h18l-1 3H4z" />
      <rect x="4" y="10" width="16" height="11" />
      <rect x="10" y="14" width="4" height="7" />
    </g>
  )}
  {name === 'mobile' && (
    <g>
      <rect x="7" y="2" width="10" height="20" rx="2" />
      <path d="M11 18h2" />
    </g>
  )}
  {name === 'design' && (
    <g>
      <path d="M4 7l8 13 8-13" />
      <path d="M4 7l8-4 8 4" />
    </g>
  )}

  {/* Systems-strip icons */}
  {name === 'aws' && (
    <g>
      <path d="M4 14c0 3 3 5 8 5s8-2 8-5" />
      <path d="M7 11l2-4 2 4M9 9.5h1M12 7h3v4M17 7h2" />
    </g>
  )}
  {name === 'azure' && (
    <g>
      <path d="M4 19l7-14 3 6-7 8zM11 19l7-14 2 14z" />
    </g>
  )}
  {name === 'cloudflare' && (
    <g>
      <path d="M7 17a4 4 0 1 1 .7-7.9A5 5 0 0 1 17 9a4 4 0 0 1 0 8H7z" />
      <path d="M9 13l4 2-4 2" />
    </g>
  )}
  {name === 'gcp' && (
    <g>
      <path d="M7 17a4 4 0 1 1 .7-7.9A5 5 0 0 1 17 9a4 4 0 0 1 0 8H7z" />
      <circle cx="12" cy="13" r="1.5" />
    </g>
  )}
  {name === 'app' && (
    <g>
      <rect x="4" y="4" width="16" height="16" rx="2" />
      <path d="M4 9h16M9 4v5" />
    </g>
  )}
  {name === 'shield' && (
    <g>
      <path d="M12 3l8 3v6c0 5-4 8-8 9-4-1-8-4-8-9V6z" />
    </g>
  )}
  {name === 'globe' && (
    <g>
      <circle cx="12" cy="12" r="9" />
      <path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18" />
    </g>
  )}
  {name === 'lock' && (
    <g>
      <rect x="5" y="10" width="14" height="10" rx="2" />
      <path d="M8 10V7a4 4 0 0 1 8 0v3" />
    </g>
  )}
  {name === 'code' && (
    <g>
      <path d="M8 6l-5 6 5 6M16 6l5 6-5 6M14 4l-4 16" />
    </g>
  )}
</svg>
