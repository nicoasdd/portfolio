    </g>
  )}

  {/* Credibility icons */}
  {name === 'frontend' && (
    <g>
      <rect x="3" y="4" width="18" height="14" rx="1.5" />
      <path d="M3 8h18M6 6.5h.01M8.5 6.5h.01" />
      <path d="M8 20h8" />
    </g>
  )}
  {name === 'fullstack' && (
    <g>
      <rect x="3" y="3" width="18" height="6" rx="1" />
      <rect x="3" y="10" width="18" height="4" rx="1" />
      <rect x="3" y="15" width="18" height="6" rx="1" />
