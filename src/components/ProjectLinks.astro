---
interface Props {
  links: {
    source?: string;
    live?: string;
    caseStudy?: string;
  };
}

const { links } = Astro.props;
const items: { href: string; label: string }[] = [];
if (links.live) items.push({ href: links.live, label: 'Live demo' });
if (links.source) items.push({ href: links.source, label: 'Source code' });
if (links.caseStudy) items.push({ href: links.caseStudy, label: 'Case study' });

const hasAny = items.length > 0;
---

{hasAny && (
  <nav aria-label="Project links">
    <ul class="flex flex-wrap items-center gap-3 list-none m-0 p-0">
      {items.map((item) => (
        <li>
          <a
            href={item.href}
            rel="noopener noreferrer"
            target="_blank"
            class="inline-flex items-center gap-1 px-4 py-2 rounded-full border border-[var(--color-border)] text-sm font-medium no-underline hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          >
            {item.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M7 17 17 7M9 7h8v8" />
            </svg>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
