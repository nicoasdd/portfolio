---
import ProjectCard from './ProjectCard.astro';
import type { ProjectWithMeta } from '../lib/projects';

interface Props {
  projects: ProjectWithMeta[];
  emptyMessage?: string;
  heading?: string;
  headingId?: string;
}

const {
  projects,
  emptyMessage = 'No projects to show yet — check back soon.',
  heading,
  headingId = 'projects',
} = Astro.props;
---

<section class="container-narrow py-8" aria-labelledby={heading ? headingId : undefined}>
  {heading && (
    <h2 id={headingId} class="text-2xl md:text-3xl font-bold mb-6">
      {heading}
    </h2>
  )}

  {projects.length === 0 ? (
    <div class="rounded-xl border border-dashed border-[var(--color-border)] p-10 text-center text-[var(--color-text-muted)]">
      <p class="m-0">{emptyMessage}</p>
    </div>
  ) : (
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 list-none m-0 p-0">
      {projects.map((p) => (
        <li>
          <ProjectCard project={p} />
        </li>
      ))}
    </ul>
  )}
</section>
