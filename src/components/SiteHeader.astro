---
import { CATEGORY_KEYS, CATEGORY_LABELS } from '../content.config';
import { withBase } from '../lib/url';

const pathname = Astro.url.pathname;
const homeHref = withBase('/');
const isActive = (href: string) => pathname === href || pathname.startsWith(href);
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur sticky top-0 z-40">
  <div class="container-narrow flex items-center justify-between gap-4 py-4">
    <a href={homeHref} class="text-lg font-bold tracking-tight no-underline text-[var(--color-text)]" aria-label="Home">
      Portfolio
    </a>

    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center rounded p-2 text-[var(--color-text)]"
      aria-label="Toggle navigation"
      aria-controls="primary-nav"
      aria-expanded="false"
      data-mobile-nav-toggle
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <nav
      id="primary-nav"
      class="hidden md:block"
      data-mobile-nav
      aria-label="Primary"
    >
      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-6 text-sm font-medium">
        <li>
          <a
            href={homeHref}
            class:list={[
              'no-underline px-2 py-1 rounded text-[var(--color-text)] hover:text-[var(--color-accent)]',
              pathname === homeHref && 'text-[var(--color-accent)]',
            ]}
            aria-current={pathname === homeHref ? 'page' : undefined}
          >
            Home
          </a>
        </li>
        {CATEGORY_KEYS.map((cat) => {
          const href = withBase(`/category/${cat}/`);
          return (
            <li>
              <a
                href={href}
                class:list={[
                  'no-underline px-2 py-1 rounded text-[var(--color-text)] hover:text-[var(--color-accent)]',
                  isActive(href) && 'text-[var(--color-accent)]',
                ]}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {CATEGORY_LABELS[cat]}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-nav-toggle]') as HTMLButtonElement | null;
  const nav = document.querySelector('[data-mobile-nav]') as HTMLElement | null;

  function setExpanded(expanded: boolean) {
    if (!toggle || !nav) return;
    toggle.setAttribute('aria-expanded', String(expanded));
    if (expanded) {
      nav.classList.remove('hidden');
      nav.classList.add('block', 'absolute', 'left-0', 'right-0', 'top-full', 'bg-[var(--color-bg)]', 'border-b', 'border-[var(--color-border)]', 'p-4');
    } else {
      nav.classList.add('hidden');
      nav.classList.remove('block', 'absolute', 'left-0', 'right-0', 'top-full', 'bg-[var(--color-bg)]', 'border-b', 'border-[var(--color-border)]', 'p-4');
    }
  }

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    setExpanded(!expanded);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setExpanded(false);
  });
</script>
