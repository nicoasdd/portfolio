---
import CategoryBadge from './CategoryBadge.astro';
import type { ProjectWithMeta } from '../lib/projects';
import { safeImagePath } from '../lib/assets';

interface Props {
  project: ProjectWithMeta;
}

const { project } = Astro.props;
const { entry, category, url } = project;
const data = entry.data;
const thumbnail = safeImagePath(data.thumbnail);
---

<article class="group h-full">
  <a
    href={url}
    class="block h-full rounded-xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-surface)] no-underline text-[var(--color-text)] transition-shadow hover:shadow-lg focus-visible:shadow-lg"
    aria-labelledby={`p-${project.slug}-title`}
  >
    <div class="aspect-[4/3] overflow-hidden bg-[var(--color-bg-subtle)]">
      <img
        src={thumbnail}
        alt={`${data.title} — preview`}
        loading="lazy"
        decoding="async"
        width="800"
        height="600"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
      />
    </div>
    <div class="p-5">
      <div class="flex items-center justify-between gap-2 mb-3">
        <CategoryBadge category={category} />
        <span class="text-xs text-[var(--color-text-muted)]">
          {data.period.start} → {data.period.end}
        </span>
      </div>
      <h3 id={`p-${project.slug}-title`} class="text-xl font-semibold m-0 leading-snug">
        {data.title}
      </h3>
      <p class="mt-2 mb-3 text-sm text-[var(--color-text-muted)] line-clamp-3">
        {data.description}
      </p>
      <ul class="flex flex-wrap gap-1.5 list-none m-0 p-0">
        {data.techStack.slice(0, 5).map((tech) => (
          <li class="text-xs px-2 py-0.5 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">
            {tech}
          </li>
        ))}
        {data.techStack.length > 5 && (
          <li class="text-xs px-2 py-0.5 rounded text-[var(--color-text-muted)]">
            +{data.techStack.length - 5}
          </li>
        )}
      </ul>
    </div>
  </a>
</article>
