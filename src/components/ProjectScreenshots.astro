---
import { safeImagePath } from '../lib/assets';

interface Props {
  screenshots: string[];
  projectTitle: string;
}

const { screenshots, projectTitle } = Astro.props;
---

{screenshots.length > 0 && (
  <section aria-label={`${projectTitle} screenshots`} class="my-10">
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 list-none m-0 p-0">
      {screenshots.map((src, i) => (
        <li class="rounded-lg overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
          <img
            src={safeImagePath(src)}
            alt={`${projectTitle} screenshot ${i + 1}`}
            loading="lazy"
            decoding="async"
            class="w-full h-auto"
          />
        </li>
      ))}
    </ul>
  </section>
)}
