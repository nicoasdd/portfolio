---
import { CATEGORY_KEYS, CATEGORY_LABELS } from '../content.config';
import { withBase } from '../lib/url';

interface Props {
  showAll?: boolean;
  ariaLabel?: string;
}

const { showAll = true, ariaLabel = 'Project categories' } = Astro.props;
const pathname = Astro.url.pathname;
const homeHref = withBase('/');

const items = [
  ...(showAll ? [{ href: homeHref, label: 'All', active: pathname === homeHref }] : []),
  ...CATEGORY_KEYS.map((cat) => {
    const href = withBase(`/category/${cat}/`);
    return { href, label: CATEGORY_LABELS[cat], active: pathname.startsWith(href) };
  }),
];
---

<nav aria-label={ariaLabel} class="my-6">
  <ul class="flex flex-wrap items-center gap-2 list-none m-0 p-0">
    {items.map((item) => (
      <li>
        <a
          href={item.href}
          class:list={[
            'inline-block px-4 py-2 rounded-full border text-sm font-medium no-underline transition-colors',
            item.active
              ? 'bg-[var(--color-accent)] text-white border-[var(--color-accent)]'
              : 'bg-transparent text-[var(--color-text)] border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]',
          ]}
          aria-current={item.active ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
