---
import PillChip from './blueprint/PillChip.astro';
import { CATEGORY_KEYS, CATEGORY_LABELS } from '../content.config';
import { withBase } from '../lib/url';

const pathname = Astro.url.pathname;
const homeHref = withBase('/');
const isActive = (href: string) =>
  href === homeHref ? pathname === homeHref : pathname.startsWith(href);

const filters: Array<{ href: string; label: string }> = [
  { href: homeHref, label: 'All' },
  ...CATEGORY_KEYS.map((cat) => ({
    href: withBase(`/category/${cat}/`),
    label: CATEGORY_LABELS[cat],
  })),
];
---

<nav aria-label="Filter projects by category" class="bp-filter-nav">
  <ul role="list" class="bp-filter-nav__list">
    {filters.map((f) => {
      const active = isActive(f.href);
      return (
        <li role="listitem">
          <PillChip
            as="a"
            href={f.href}
            active={active}
            ariaCurrent={active ? 'page' : undefined}
          >
            {f.label}
          </PillChip>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .bp-filter-nav {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .bp-filter-nav__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
