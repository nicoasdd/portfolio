---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description = 'Portfolio of personal, startup and corporate projects.',
  image,
  type = 'website',
  noindex = false,
} = Astro.props;

const siteName = 'Portfolio';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImage = image
  ? new URL(withBase(image), Astro.site ?? Astro.url).toString()
  : undefined;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b1326" id="bp-theme-color" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/*
      Inline pre-hydration theme resolver. Runs synchronously before stylesheet
      paint to eliminate the "flash of wrong theme" when a visitor has picked a
      theme that differs from the OS preference. See research.md §2.
    */}
    <script is:inline>
      (function () {
        try {
          var KEY = 'bp-theme';
          var stored = localStorage.getItem(KEY);
          var osDark =
            typeof window.matchMedia === 'function' &&
            window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored === 'light' || stored === 'dark'
            ? stored
            : osDark ? 'dark' : 'light';
          document.documentElement.dataset.theme = theme;
          var meta = document.getElementById('bp-theme-color');
          if (meta) {
            meta.setAttribute('content', theme === 'dark' ? '#0b1326' : '#f2f5fb');
          }
        } catch {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:site_name" content={siteName} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body class="bp-grid-bg">
    <a href="#main" class="skip-link">Skip to main content</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
