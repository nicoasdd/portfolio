---
import BaseLayout from './BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import TechStack from '../components/TechStack.astro';
import ProjectLinks from '../components/ProjectLinks.astro';
import CornerFrame from '../components/blueprint/CornerFrame.astro';
import type { ProjectWithMeta } from '../lib/projects';
import { withBase } from '../lib/url';

interface Props {
  project: ProjectWithMeta;
}

const { project } = Astro.props;
const { entry, category } = project;
const data = entry.data;
const categoryHref = withBase(`/category/${category}/`);
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.thumbnail}
  type="article"
>
  <article class="container-narrow bp-project">
    <nav aria-label="Breadcrumb" class="bp-project__crumbs">
      <ol>
        <li><a href={withBase('/')}>Home</a></li>
        <li aria-hidden="true"><span>/</span></li>
        <li><a href={categoryHref}>{category}</a></li>
        <li aria-hidden="true"><span>/</span></li>
        <li aria-current="page">{data.title}</li>
      </ol>
    </nav>

    <header class="bp-project__header">
      <div class="bp-project__meta-row">
        <CategoryBadge category={category} size="md" />
        <span class="bp-project__period">
          {data.period.start} → {data.period.end}
        </span>
      </div>
      <h1 class="bp-project__title">{data.title}</h1>
      <p class="bp-project__description">{data.description}</p>

      <CornerFrame padding="md" class="bp-project__meta-card">
        <dl class="bp-project__meta">
          <div>
            <dt>Role</dt>
            <dd>{data.role}</dd>
          </div>
          <div>
            <dt>Period</dt>
            <dd>{data.period.start} → {data.period.end}</dd>
          </div>
          <div class="bp-project__meta--wide">
            <dt>Tech stack</dt>
            <dd><TechStack items={data.techStack} /></dd>
          </div>
          {(data.links.source || data.links.live || data.links.caseStudy) && (
            <div class="bp-project__meta--wide">
              <dt>Links</dt>
              <dd><ProjectLinks links={data.links} /></dd>
            </div>
          )}
        </dl>
      </CornerFrame>
    </header>

    <div class="bp-prose bp-project__body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .bp-project {
    padding: 2rem 1rem 3rem;
  }

  @media (min-width: 768px) {
    .bp-project {
      padding: 2.5rem 2rem 3rem;
    }
  }

  .bp-project__crumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    font-size: var(--text-bp-sm);
    color: var(--bp-text-mut);
    text-transform: capitalize;
  }

  .bp-project__crumbs a {
    color: var(--bp-text-mut);
    text-decoration: none;
  }

  .bp-project__crumbs a:hover {
    color: var(--bp-accent);
  }

  .bp-project__crumbs li[aria-current='page'] {
    color: var(--bp-accent);
  }

  .bp-project__header {
    margin-bottom: 2rem;
  }

  .bp-project__meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .bp-project__period {
    font-family: var(--font-bp-mono);
    font-size: var(--text-bp-xs);
    color: var(--bp-text-mut);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .bp-project__title {
    font-size: var(--text-bp-hero);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
  }

  .bp-project__description {
    font-size: var(--text-bp-lg);
    color: var(--bp-text-mut);
    max-width: 65ch;
    margin: 0 0 1.5rem;
    line-height: 1.55;
  }

  .bp-project__meta-card {
    margin-top: 1.25rem;
  }

  .bp-project__meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0;
  }

  @media (min-width: 768px) {
    .bp-project__meta {
      grid-template-columns: repeat(2, 1fr);
    }
    .bp-project__meta--wide {
      grid-column: 1 / -1;
    }
  }

  .bp-project__meta dt {
    font-family: var(--font-bp-mono);
    font-size: var(--text-bp-xs);
    color: var(--bp-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 0.25rem;
  }

  .bp-project__meta dd {
    margin: 0;
    color: var(--bp-text);
    font-size: var(--text-bp-sm);
  }

  .bp-project__body {
    max-width: 72ch;
    margin-top: 2rem;
  }
</style>
