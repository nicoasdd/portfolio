---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { CATEGORY_KEYS, CATEGORY_LABELS, type CategoryKey } from '../../content.config';
import { getByCategory } from '../../lib/projects';

export async function getStaticPaths() {
  return CATEGORY_KEYS.map((category) => ({
    params: { category },
    props: { category },
  }));
}

interface Props {
  category: CategoryKey;
}

const { category } = Astro.props;
const projects = await getByCategory(category);
const label = CATEGORY_LABELS[category];
---

<BaseLayout
  title={`${label} projects`}
  description={`${label} projects — a curated list of ${label.toLowerCase()} work in this portfolio.`}
>
  <section class="container-narrow pt-12 pb-4">
    <p class="text-sm uppercase tracking-wide text-[var(--color-text-muted)] m-0">Category</p>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mt-2 m-0">{label} projects</h1>
    <p class="mt-4 max-w-2xl text-lg text-[var(--color-text-muted)]">
      {projects.length === 0
        ? `No ${label.toLowerCase()} projects published yet.`
        : `${projects.length} ${label.toLowerCase()} project${projects.length === 1 ? '' : 's'}.`}
    </p>
    <CategoryNav />
  </section>
  <ProjectGrid
    projects={projects}
    emptyMessage={`No ${label.toLowerCase()} projects published yet — add a Markdown file under src/content/projects/${category}/.`}
  />
</BaseLayout>
