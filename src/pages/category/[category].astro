---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryHero from '../../components/CategoryHero.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import FeaturedProjectCard from '../../components/FeaturedProjectCard.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { CATEGORY_KEYS, CATEGORY_LABELS, type CategoryKey } from '../../content.config';
import { getByCategory } from '../../lib/projects';

export async function getStaticPaths() {
  return CATEGORY_KEYS.map((category) => ({
    params: { category },
    props: { category },
  }));
}

interface Props {
  category: CategoryKey;
}

const { category } = Astro.props;
const projects = await getByCategory(category);
const label = CATEGORY_LABELS[category];
const featured = projects.filter((p) => p.entry.data.featured);
const rest = projects.filter((p) => !p.entry.data.featured);
---

<BaseLayout
  title={`${label} projects`}
  description={`${label} projects — a curated list of ${label.toLowerCase()} work in this portfolio.`}
>
  <CategoryHero category={category} />

  <div class="container-narrow">
    <CategoryNav />

    {featured.length > 0 && (
      <section aria-labelledby="featured-label" class="bp-featured-band">
        <h2 id="featured-label" class="bp-eyebrow">
          Featured {label.toLowerCase()} projects
        </h2>
        {featured.map((p, i) => (
          <FeaturedProjectCard project={p} index={i + 1} />
        ))}
      </section>
    )}
  </div>

  <ProjectGrid
    projects={rest.length > 0 ? rest : featured.length === 0 ? projects : []}
    heading={featured.length > 0 ? `More ${label.toLowerCase()} projects` : `${label} projects`}
    headingId="projects"
    emptyMessage={`No ${label.toLowerCase()} projects published yet — add a Markdown file under src/content/projects/${category}/.`}
    startIndex={featured.length + 1}
  />
</BaseLayout>

<style>
  .bp-featured-band {
    padding: 1rem 0 0.5rem;
  }

  .bp-featured-band .bp-eyebrow {
    display: block;
    margin-bottom: 1rem;
  }
</style>
