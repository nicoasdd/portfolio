---
import { render } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import ProjectScreenshots from '../../components/ProjectScreenshots.astro';
import { getAllProjects, type ProjectWithMeta } from '../../lib/projects';

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: ProjectWithMeta;
}

const { project } = Astro.props;
const { Content } = await render(project.entry);
const data = project.entry.data;
const hasBody = (project.entry.body ?? '').trim().length > 0;
---

<ProjectLayout project={project}>
  {hasBody ? (
    <Content />
  ) : (
    <p class="text-[var(--color-text-muted)] italic">No description provided.</p>
  )}

  <ProjectScreenshots screenshots={data.screenshots ?? []} projectTitle={data.title} />
</ProjectLayout>
