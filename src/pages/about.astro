---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutHero from '../components/AboutHero.astro';
import ValueGrid from '../components/ValueGrid.astro';
import ProcessBanner from '../components/ProcessBanner.astro';
import SkillsList from '../components/SkillsList.astro';
import ElsewhereList from '../components/ElsewhereList.astro';
import { getAbout } from '../lib/about';

const profile = await getAbout();
const { data, effectiveAlt, availabilityPills, values, process, processStatement, contact } = profile;
const { Content } = await render(profile.entry);
---

<BaseLayout
  title="About"
  description={data.intro}
  image={data.photo}
  type="article"
>
  <AboutHero
    data={data}
    availabilityPills={availabilityPills}
    contact={contact}
    effectiveAlt={effectiveAlt}
  />

  <article class="container-narrow bp-about-article">
    <section
      aria-labelledby="about-bio-heading"
      class="bp-about-bio"
    >
      <h2 id="about-bio-heading" class="bp-eyebrow">About me</h2>
      <div class="bp-prose">
        <Content />
      </div>
    </section>

    <ValueGrid values={values} />

    <ProcessBanner steps={process} statement={processStatement} />

    <section aria-labelledby="about-skills-heading" class="bp-about-skills">
      <h2 id="about-skills-heading" class="bp-eyebrow">Skills</h2>
      <SkillsList skills={data.skills} />
    </section>

    <ElsewhereList contact={contact} />
  </article>
</BaseLayout>

<style>
  .bp-about-article {
    padding: 1rem 1rem 1rem;
  }

  @media (min-width: 768px) {
    .bp-about-article {
      padding: 1rem 2rem 1rem;
    }
  }

  .bp-about-bio {
    max-width: 65ch;
    margin-top: 2rem;
  }

  .bp-about-bio .bp-eyebrow {
    display: block;
    margin-bottom: 1rem;
  }

  .bp-about-skills {
    margin-top: 2.5rem;
  }

  .bp-about-skills .bp-eyebrow {
    display: block;
    margin-bottom: 1rem;
  }
</style>
