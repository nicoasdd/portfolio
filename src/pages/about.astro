---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillsList from '../components/SkillsList.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getAbout } from '../lib/about';
import { safeImagePath } from '../lib/assets';

const profile = await getAbout();
const { data, effectiveAlt, resumeHref } = profile;
const { Content } = await render(profile.entry);
const photoSrc = safeImagePath(data.photo);

const isExternalResume = resumeHref ? /^https?:\/\//.test(resumeHref) : false;
const resumeRel = isExternalResume ? 'noopener noreferrer' : undefined;
const resumeTarget = isExternalResume ? '_blank' : undefined;
const resumeDownload = !isExternalResume;
---

<BaseLayout
  title="About"
  description={data.intro}
  image={data.photo}
  type="article"
>
  <article class="container-narrow pt-12 pb-16">
    <header class="md:grid md:grid-cols-[200px_1fr] md:gap-10 md:items-start border-b border-[var(--color-border)] pb-8">
      <div class="mb-6 md:mb-0">
        <img
          src={photoSrc}
          alt={effectiveAlt}
          loading="eager"
          decoding="async"
          width="320"
          height="320"
          class="block w-40 h-40 md:w-48 md:h-48 rounded-full object-cover bg-[var(--color-bg-subtle)] border border-[var(--color-border)]"
        />
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] m-0">
          About
        </p>
        <h1 class="mt-2 text-4xl md:text-5xl font-bold tracking-tight m-0">{data.name}</h1>
        <p class="mt-3 text-lg md:text-xl text-[var(--color-text-muted)] m-0">{data.headline}</p>

        {(data.location || data.availability) && (
          <address class="mt-4 not-italic flex flex-wrap gap-2 text-sm">
            {data.location && (
              <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-[var(--color-bg-subtle)] text-[var(--color-text)] border border-[var(--color-border)]">
                {data.location}
              </span>
            )}
            {data.availability && (
              <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/30">
                {data.availability}
              </span>
            )}
          </address>
        )}

        <div class="mt-6 flex flex-wrap items-center gap-3">
          <a
            href={`mailto:${data.email}`}
            aria-label={`Email ${data.name}`}
            class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-md no-underline bg-[var(--color-accent)] text-white hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            Email {data.name.split(' ')[0]}
          </a>
          {resumeHref && (
            <a
              href={resumeHref}
              target={resumeTarget}
              rel={resumeRel}
              download={resumeDownload}
              class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-md no-underline border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download CV
            </a>
          )}
        </div>
      </div>
    </header>

    <section
      aria-labelledby="about-bio-heading"
      class="prose prose-lg max-w-none mt-10 [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:mt-10 [&>h2]:mb-3 [&>h3]:text-xl [&>h3]:font-semibold [&>h3]:mt-8 [&>h3]:mb-2 [&>p]:my-4 [&>ul]:my-4 [&>ul]:list-disc [&>ul]:pl-6 [&>ol]:my-4 [&>ol]:list-decimal [&>ol]:pl-6"
    >
      <h2 id="about-bio-heading" class="sr-only">About me</h2>
      <Content />
    </section>

    <section
      aria-labelledby="about-skills-heading"
      class="mt-12 border-t border-[var(--color-border)] pt-8"
    >
      <h2
        id="about-skills-heading"
        class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] m-0 mb-4"
      >
        Skills
      </h2>
      <SkillsList skills={data.skills} />
    </section>

    {data.socialLinks.length > 0 && (
      <section aria-labelledby="about-social-heading" class="mt-10">
        <h2
          id="about-social-heading"
          class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] m-0 mb-4"
        >
          Elsewhere
        </h2>
        <SocialLinks links={data.socialLinks} ariaLabel="Social and elsewhere" />
      </section>
    )}
  </article>
</BaseLayout>
